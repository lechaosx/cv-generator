{
  "name": "cv-generator-editor",
  "private": true,
  "scripts": {
    "build":     "esbuild editor/index.ts --bundle --outfile=server/static/edit.js --platform=browser --target=es2022 --define:DEBUG=false",
    "build:css": "sass scss/style.scss server/static/style.css --style=compressed --no-source-map",
    "serve":     "node build.mjs"
  },
  "devDependencies": {
    "esbuild":             "^0.28.0",
    "esbuild-sass-plugin": "^3.7.0",
    "sass":                "^1.97.3",
    "sass-embedded":       "^1.97.3",
    "typescript":          "^5.7.3"
  }
}
